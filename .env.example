# Gemini AI — script generation
GEMINI_API_KEY=your_gemini_key

# Microsoft Edge TTS — free Arabic TTS (no API key needed)
# Optional: override voice (default: ar-SA-HamedNeural)
# Other options: ar-SA-ZariyahNeural, ar-EG-ShakirNeural, ar-EG-SalmaNeural
EDGE_TTS_VOICE=ar-SA-HamedNeural

# Cloudflare Workers AI — image generation
CF_ACCOUNT_ID=your_cloudflare_account_id
CF_API_TOKEN=your_cloudflare_api_token
# Optional: override model (default: flux-1-schnell)
# Other options: @cf/lykon/dreamshaper-8-lcm, @cf/stabilityai/stable-diffusion-xl-base-1.0
CF_IMAGE_MODEL=@cf/black-forest-labs/flux-1-schnell
